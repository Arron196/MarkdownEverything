APP_ENV=development
SECRET_KEY=change-me-before-production
DATABASE_URL=postgresql+psycopg://markdown:markdown@postgres:5432/markdown_everything
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
STORAGE_ROOT=/data/markdown-everything
FRONTEND_ORIGIN=http://localhost
NEXT_PUBLIC_API_BASE_URL=http://localhost/api

# AI summary, OpenAI-compatible chat completions.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# ASR provider: local_whisper or cloud_openai_compatible
ASR_PROVIDER=local_whisper
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
ASR_BASE_URL=
ASR_API_KEY=
ASR_MODEL=whisper-1

MAX_UPLOAD_MB=500
MAX_WEB_RESPONSE_MB=20
GUEST_RETENTION_HOURS=24
USER_RETENTION_DAYS=7
USER_CONCURRENCY_LIMIT=3
GUEST_CONCURRENCY_LIMIT=1
JOB_TIMEOUT_MINUTES=60
